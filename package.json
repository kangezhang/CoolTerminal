{
  "name": "coolterminal",
  "version": "1.0.0",
  "description": "现代化终端 - 支持 Windows/Mac/Linux",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.coolterminal.app",
    "productName": "CoolTerminal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "static/**/*",
      "templates/**/*",
      "assets/**/*",
      "main.py",
      "requirements.txt",
      "!node_modules/**/*",
      "!dist/**/*"
    ],
    "extraResources": [
      {
        "from": "main.py",
        "to": "app/main.py"
      },
      {
        "from": "requirements.txt",
        "to": "app/requirements.txt"
      },
      {
        "from": "static",
        "to": "app/static"
      },
      {
        "from": "templates",
        "to": "app/templates"
      },
      {
        "from": "assets",
        "to": "app/assets"
      },
      {
        "from": "dist/server/coolterminal_server",
        "to": "server"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon_terminal.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "requestedExecutionLevel": "highestAvailable"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon_terminal.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon_terminal.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CoolTerminal",
      "installerIcon": "assets/icon_terminal.ico",
      "uninstallerIcon": "assets/icon_terminal.ico",
      "installerHeaderIcon": "assets/icon_terminal.ico"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "icon": "assets/icon_terminal.ico"
    }
  },
  "keywords": [
    "terminal",
    "command-line",
    "cli",
    "shell"
  ],
  "author": "CoolTerminal Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {}
}
